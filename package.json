        "@types/express": "^5.0.6",
        "better-auth": "^1.5.6",
        "drizzle-orm": "^0.45.1",
        "express": "^5.2.1",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/node": "^22.13.10",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "drizzle-kit": "^0.31.10",
        "eslint": "^10.1.0",
        "tsx": "^4.19.3",
        "typescript": "^5.8.2"
    }
