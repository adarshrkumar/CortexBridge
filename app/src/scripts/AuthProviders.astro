<script>
    import { createAuthClient } from 'better-auth/client';

    const authClient = createAuthClient();

    const auth = document.querySelector<HTMLElement>('.auth');

    if (auth) {
        document.addEventListener('mousemove', (e) => {
            const rect = auth.getBoundingClientRect();
            auth.style.setProperty('--x', `${e.clientX - rect.left}px`);
            auth.style.setProperty('--y', `${e.clientY - rect.top}px`);
        });
    }

    document.querySelectorAll<HTMLButtonElement>('[data-provider]').forEach((btn) => {
        btn.addEventListener('click', async () => {
            await authClient.signIn.social({
                provider: btn.dataset.provider as 'google' | 'github',
                callbackURL: '/',
            });
        });
    });
</script>
