{
    "name": "@cortexbridge/app",
    "type": "module",
    "version": "0.0.1",
    "engines": {
        "node": ">=22.12.0"
    },
    "scripts": {
        "styles:scss": "node ../styles/scripts/generate-colors.mjs && node ../styles/scripts/generate-tokens.mjs && node ../styles/scripts/generate-mixins.mjs",
        "dev": "npm run styles:scss && astro dev",
        "build": "npm run styles:scss && astro build",
        "preview": "astro preview",
        "astro": "astro",
        "check": "npm run styles:scss && stylelint \"src/**/*.scss\" && astro check"
    },
    "dependencies": {
        "astro": "^6.1.1",
        "better-auth": "^1.5.6",
        "dotenv": "^16.4.7",
        "sass": "^1.98.0"
    },
    "devDependencies": {
        "@astrojs/check": "^0.9.8",
        "typescript": "^5.9.3"
    }
}
